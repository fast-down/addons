{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!!**/dist", "!!src/options.html", "!!src/vendor"]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "all",
      "suspicious": {
        "noImportCycles": "off"
      },
      "correctness": {
        "useQwikValidLexicalScope": "off"
      }
    }
  },
  "javascript": {
    "globals": ["chrome", "browser"]
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
